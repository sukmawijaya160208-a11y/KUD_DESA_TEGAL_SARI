APP_NAME="KUD Desa Sari Subur"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://kud-sari-subur.my.id

# Frontend URL untuk CORS
FRONTEND_URL=https://kud-sari-subur.my.id

# Sanctum stateful domains (pisah dengan koma)
SANCTUM_STATEFUL_DOMAINS=kud-sari-subur.my.id

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=kud_desa_sari_subur
# DB_USERNAME=kud_user
# DB_PASSWORD=isi_password_kuat_disini

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.kud-sari-subur.my.id
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=isi_username
MAIL_PASSWORD=isi_password
MAIL_FROM_ADDRESS="noreply@kud-sari-subur.my.id"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
